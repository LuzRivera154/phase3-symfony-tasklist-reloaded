{{ form_start(form) }}
<div class="flex flex-col gap-5">
	<label for="{{form.title.vars.id}}" class="label">Titre de la tâche</label>
	{{ form_widget(form.title,{'attr':{class:"input", placeholder:"Faire les courses"}}) }}
	<label for="{{form.priority.vars.id}}" class="label">Priorité</label>
	{{ form_widget(form.priority,{'attr':{class:"input"}}) }}
	<label for="{{form.Folder.vars.id}}" class="label">Dossier (optionnel)</label>
	{{ form_widget(form.Folder,{'attr':{class:"input"}}) }}
	<div class="flex justify-end gap-3">
		<a href="{{ path('app_task_index') }}" class="btn btn-secondary">Annuler</a>
		<button class="btn btn-primary">{{ button_label|default('Créer') }}</button>
	</div>
</div>
{{ form_end(form) }}
